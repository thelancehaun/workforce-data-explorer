# Copy this file to .env and fill in your API keys
# All keys are free to obtain — links below

# FRED (Federal Reserve Bank of St. Louis)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BLS (Bureau of Labor Statistics)
# Register at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# Census Bureau
# Register at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# O*NET (no key required — uses public API)
# Optional: Register at https://services.onetcenter.org/ for higher rate limits
ONET_API_KEY=

# DOL Open Data Portal (required for OSHA/WHD/VETS-4212 enforcement data)
# Register free at: https://dataportal.dol.gov
DOL_API_KEY=

# Groq (powers the AI Assistant chat)
# Register free at: https://console.groq.com
GROQ_API_KEY=
